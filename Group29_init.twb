                    <run fontcolor='#000000' fontname='Benton Sans Book'>XGBoost tuned achieves the lowest RMSE of ~$29,820, meaning predictions are off by ~$30K on average. Lower is better</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='280' h='42500' id='6' is-fixed='true' name='Model Comparison' w='49200' x='800' y='50000'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone h='8375' id='9' type-v2='text' w='49200' x='50000' y='90625'>
                  <formatted-text>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>Points cluster along the diagonal, showing predictions track actual salaries well. Spread increases at higher salaries — the model underestimates very high earners</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone h='6500' id='8' type-v2='text' w='49200' x='800' y='92500'>
                  <formatted-text>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>XGBoost with hyperparameter tuning achieves R²=0.67, explaining 67% of salary variance — a meaningful improvement over the Linear Regression baseline of 0.597</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
              </zone>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='8' />
              </zone-style>
            </zone>
          </zones>
        </devicelayout>
      </devicelayouts>
      <simple-id uuid='{811D8C0A-6DAD-4BFA-A6E3-38F77D6A5171}' />
    </dashboard>
    <dashboard enable-sort-zone-taborder='true' name='What Drives Salary'>
      <style />
      <size maxheight='800' maxwidth='1000' minheight='800' minwidth='1000' />
