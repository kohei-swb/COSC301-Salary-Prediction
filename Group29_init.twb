    <datasource caption='Custom SQL Query (salary_prediction)' inline='true' name='federated.0tkyrxn17qd5xl1d7zjnh0i4v846' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='localhost' name='mysql.0qj6xlf0fujd5r1dcfoc614bnalf'>
            <connection class='mysql' dbname='salary_prediction' odbc-native-protocol='' one-time-sql='' port='3306' server='localhost' source-charset='' username='root' />
          </named-connection>
        </named-connections>
        <relation connection='mysql.0qj6xlf0fujd5r1dcfoc614bnalf' name='Custom SQL Query' type='text'>SELECT l.language_name, AVG(d.converted_comp_yearly) as avg_salary
FROM developers d
JOIN developer_languages dl ON d.respondent_id = dl.respondent_id
JOIN languages l ON dl.language_id = l.language_id
GROUP BY l.language_name
ORDER BY avg_salary DESC
LIMIT 15</relation>
